[gd_scene load_steps=2 format=3 uid="uid://bv75s51vuri2l"]

[sub_resource type="GDScript" id="GDScript_kuov4"]
script/source = "extends Control

# 预加载场景文件
var level_x_scene = preload(\"res://scenes/world/level_x.tscn\")
var level_100_scene = preload(\"res://scenes/world/vip_level/level_100.tscn\")

# UI元素
@onready var generate_button: Button
@onready var clear_button: Button
@onready var scroll_container: ScrollContainer
@onready var levels_container: VBoxContainer

# 存储生成的楼层实例
var generated_levels = []

func _ready():
	# 创建UI界面
	_setup_ui()

func _setup_ui():
	# 创建主容器
	var main_container = VBoxContainer.new()
	add_child(main_container)
	
	# 创建按钮容器
	var button_container = HBoxContainer.new()
	main_container.add_child(button_container)
	
	# 创建生成按钮
	generate_button = Button.new()
	generate_button.text = \"生成1-100层\"
	generate_button.pressed.connect(_on_generate_button_pressed)
	button_container.add_child(generate_button)
	
	# 创建清除按钮
	clear_button = Button.new()
	clear_button.text = \"清除所有楼层\"
	clear_button.pressed.connect(_on_clear_button_pressed)
	button_container.add_child(clear_button)
	
	# 创建滚动容器
	scroll_container = ScrollContainer.new()
	scroll_container.size_flags_vertical = Control.SIZE_EXPAND_FILL
	main_container.add_child(scroll_container)
	
	# 创建楼层容器
	levels_container = VBoxContainer.new()
	levels_container.size_flags_horizontal = Control.SIZE_EXPAND_FILL
	scroll_container.add_child(levels_container)

func _on_generate_button_pressed():
	# 清除已生成的楼层
	_clear_levels()
	
	# 生成1-100层
	for i in range(1, 101):
		_create_level(i)

func _on_clear_button_pressed():
	_clear_levels()

func _clear_levels():
	# 清除所有已生成的楼层
	for level in generated_levels:
		if is_instance_valid(level):
			level.queue_free()
	generated_levels.clear()
	
	# 清除容器中的子节点
	for child in levels_container.get_children():
		child.queue_free()

func _create_level(level_number: int):
	# 创建楼层标签
	var level_label = Label.new()
	level_label.text = \"第 %d 层\" % level_number
	levels_container.add_child(level_label)
	
	# 创建楼层实例
	var level_instance
	if level_number == 100:
		level_instance = level_100_scene.instantiate()
	else:
		level_instance = level_x_scene.instantiate()
	
	# 设置楼层位置
	level_instance.position = Vector2(0, level_number * 50)  # 每层间隔50像素
	
	# 添加到容器
	levels_container.add_child(level_instance)
	generated_levels.append(level_instance)
"

